GEMINI_API_KEY=
LAW_API_KEY=
# 기본: flash-lite (RPM·비용 절약). full 품질이 필요하면 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite
# 429는 동일 쿼터 풀이라 추가 시도 안 함. 404/5xx 시에만 pro 등으로 폴백
# GEMINI_MODEL_FALLBACK=gemini-2.5-pro
# 요약 모드: lite(기본, 짧은 프롬프트·400토큰) | full | off
# GEMINI_SUMMARY_MODE=lite
# GEMINI_SUMMARY_MAX_TOKENS=400
# SKIP_GEMINI_SUMMARY=1
# --- Planner 모드 (예정: route 연동 전까지는 내부 검색어만) ---
# GEMINI_PLANNER_MODE=on
# GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
# GEMINI_PLANNER_MODEL_FALLBACK=gemini-2.5-flash,gemini-2.5-pro
# Planner on일 때 요약 끄기 권장 (RPD 20/일 공유)
# GEMINI_SUMMARY_MODE=off
